{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "_generator": {
      "name": "bicep",
      "version": "0.41.2.15936",
      "templateHash": "14759253056969658096"
    }
  },
  "parameters": {
    "locationEast": {
      "type": "string",
      "defaultValue": "eastus",
      "metadata": {
        "description": "Location for storage and key vault"
      }
    },
    "locationWest": {
      "type": "string",
      "defaultValue": "westus2",
      "metadata": {
        "description": "Location for function app and static web app"
      }
    },
    "alphaVantageKey": {
      "type": "securestring"
    }
  },
  "resources": [
    {
      "type": "Microsoft.Storage/storageAccounts",
      "apiVersion": "2022-09-01",
      "name": "stockdashstorage",
      "location": "[parameters('locationEast')]",
      "sku": {
        "name": "Standard_LRS"
      },
      "kind": "StorageV2"
    },
    {
      "type": "Microsoft.KeyVault/vaults",
      "apiVersion": "2022-07-01",
      "name": "stock-dashboard-project",
      "location": "[parameters('locationEast')]",
      "properties": {
        "sku": {
          "family": "A",
          "name": "standard"
        },
        "tenantId": "[subscription().tenantId]",
        "enableRbacAuthorization": true
      }
    },
    {
      "type": "Microsoft.KeyVault/vaults/secrets",
      "apiVersion": "2022-07-01",
      "name": "[format('{0}/{1}', 'stock-dashboard-project', 'AlphaVantageKey')]",
      "properties": {
        "value": "[parameters('alphaVantageKey')]"
      },
      "dependsOn": [
        "[resourceId('Microsoft.KeyVault/vaults', 'stock-dashboard-project')]"
      ]
    },
    {
      "type": "Microsoft.Web/serverfarms",
      "apiVersion": "2022-03-01",
      "name": "stock-dashboard-plan",
      "location": "[parameters('locationWest')]",
      "sku": {
        "name": "Y1",
        "tier": "Dynamic"
      },
      "kind": "linux",
      "properties": {
        "reserved": true
      }
    },
    {
      "type": "Microsoft.Web/sites",
      "apiVersion": "2022-03-01",
      "name": "stock-dashboard-func",
      "location": "[parameters('locationWest')]",
      "kind": "functionapp,linux",
      "identity": {
        "type": "SystemAssigned"
      },
      "properties": {
        "serverFarmId": "[resourceId('Microsoft.Web/serverfarms', 'stock-dashboard-plan')]",
        "siteConfig": {
          "linuxFxVersion": "Python|3.11",
          "appSettings": [
            {
              "name": "AzureWebJobsStorage",
              "value": "[format('DefaultEndpointsProtocol=https;AccountName={0};EndpointSuffix={1};AccountKey={2}', 'stockdashstorage', environment().suffixes.storage, listKeys(resourceId('Microsoft.Storage/storageAccounts', 'stockdashstorage'), '2022-09-01').keys[0].value)]"
            },
            {
              "name": "FUNCTIONS_EXTENSION_VERSION",
              "value": "~4"
            },
            {
              "name": "FUNCTIONS_WORKER_RUNTIME",
              "value": "python"
            }
          ]
        },
        "httpsOnly": true
      },
      "dependsOn": [
        "[resourceId('Microsoft.Web/serverfarms', 'stock-dashboard-plan')]",
        "[resourceId('Microsoft.Storage/storageAccounts', 'stockdashstorage')]"
      ]
    },
    {
      "type": "Microsoft.Authorization/roleAssignments",
      "apiVersion": "2022-04-01",
      "scope": "[resourceId('Microsoft.KeyVault/vaults', 'stock-dashboard-project')]",
      "name": "6ecbb327-1ced-4853-bcbe-5a923e2b95c5",
      "properties": {
        "roleDefinitionId": "[subscriptionResourceId('Microsoft.Authorization/roleDefinitions', '4633458b-17de-408a-b874-0445c86b69e6')]",
        "principalId": "[reference(resourceId('Microsoft.Web/sites', 'stock-dashboard-func'), '2022-03-01', 'full').identity.principalId]",
        "principalType": "ServicePrincipal"
      },
      "dependsOn": [
        "[resourceId('Microsoft.Web/sites', 'stock-dashboard-func')]",
        "[resourceId('Microsoft.KeyVault/vaults', 'stock-dashboard-project')]"
      ]
    },
    {
      "type": "Microsoft.Web/staticSites",
      "apiVersion": "2022-03-01",
      "name": "stock-dashboard-ui",
      "location": "[parameters('locationWest')]",
      "sku": {
        "name": "Free",
        "tier": "Free"
      },
      "properties": {}
    }
  ],
  "outputs": {
    "functionAppUrl": {
      "type": "string",
      "value": "[format('https://{0}', reference(resourceId('Microsoft.Web/sites', 'stock-dashboard-func'), '2022-03-01').defaultHostName)]"
    },
    "staticWebAppUrl": {
      "type": "string",
      "value": "[format('https://{0}', reference(resourceId('Microsoft.Web/staticSites', 'stock-dashboard-ui'), '2022-03-01').defaultHostname)]"
    },
    "keyVaultName": {
      "type": "string",
      "value": "stock-dashboard-project"
    }
  }
}